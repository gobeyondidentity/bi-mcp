{
  "name": "@beyondidentity/mcp",
  "version": "0.1.0",
  "description": "MCP server for the Beyond Identity public APIs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gobeyondidentity/bi-mcp.git"
  },
  "keywords": [
    "auth",
    "sso",
    "iam",
    "beyond",
    "identity"
  ],
  "author": "Sam Huckaby",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/gobeyondidentity/bi-mcp/issues"
  },
  "homepage": "https://github.com/gobeyondidentity/bi-mcp#readme",
  "type": "module",
  "bin": {
    "beyondidentity-mcp": "./dist/index.js"
  },
  "scripts": {
    "generate": "tsx scripts/patch-spec.ts && tsx scripts/generate.ts",
    "build": "npm run generate && tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit && tsc --project tsconfig.test.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "prepare": "husky && node scripts/check-hooks-path.js",
    "prepublishOnly": "npm run build && npm run lint && npm test"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --max-warnings 0"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.0.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^10.0.0",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "yaml": "^2.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "openapi.yaml",
    "openapi-v0.yaml"
  ]
}
